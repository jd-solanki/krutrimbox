{
  "name": "krutrimbox",
  "version": "0.0.3",
  "type": "module",
  "bin": {
    "kb": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "release": "bumpp",
    "sandbox:build-template": "docker build -f Dockerfile.sandbox -t krutrimbox-codex:pnpm .",
    "sandbox:load-template": "docker image save krutrimbox-codex:pnpm -o /tmp/krutrimbox-codex-pnpm.tar && sbx template load /tmp/krutrimbox-codex-pnpm.tar",
    "sandbox:prepare-template": "pnpm sandbox:build-template && pnpm sandbox:load-template",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pkg:link": "pnpm link --global",
    "pkg:unlink": "pnpm unlink --global krutrimbox"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "bumpp": "^10.2.3",
    "tsdown": "^0.16.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.23.0"
}