{
  "name": "code-factory",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "code-factory": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "sandbox:build-template": "docker build -f Dockerfile.sandbox -t code-factory-codex:pnpm .",
    "sandbox:load-template": "docker image save code-factory-codex:pnpm -o /tmp/code-factory-codex-pnpm.tar && sbx template load /tmp/code-factory-codex-pnpm.tar",
    "sandbox:prepare-template": "pnpm sandbox:build-template && pnpm sandbox:load-template",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.23.0"
}
